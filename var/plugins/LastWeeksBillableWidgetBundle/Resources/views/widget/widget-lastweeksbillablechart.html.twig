{% set chart_id = options.id %}

{% embed '@theme/embeds/card.html.twig' with {'margin_bottom': 0} %}
    {% from '@theme/components/buttons.html.twig' import action_cardtoolbutton %}
    {% block box_title %}
        {% if not title is empty %}
            {{ title|trans }} - {{ data.period.date|month_name }} {{ data.period.date|date_format('Y') }} - {{ data.period.billableHours }}h - {{ data.period.billablePercent }}%
        {% endif %}
    {% endblock %}
    {% block box_attributes %}
        id="LastWeeksBillableChartBox" data-href="#" data-reload=""
    {% endblock %}
    {% block box_tools %}
        {{ action_cardtoolbutton('left', {'title': data.previous.date|month_name ~ ' ' ~ data.previous.date|date_format('Y'), 'class': 'pagination-link', 'onclick': 'window.destroyLastWeeksBillableChart && window.destroyLastWeeksBillableChart()', 'url': path('widgets_last_weeks_billable_chart', {'year': data.previous.year, 'month': data.previous.month})}) }}
        {{ action_cardtoolbutton('right', {'title': data.next.date|month_name ~ ' ' ~ data.next.date|date_format('Y'), 'class': 'pagination-link', 'onclick': 'window.destroyLastWeeksBillableChart && window.destroyLastWeeksBillableChart()', 'url': path('widgets_last_weeks_billable_chart', {'year': data.next.year, 'month': data.next.month})}) }}
    {% endblock %}
    {% block box_body %}
        {{ render_widget('LastWeeksBillableChartCanvas', {'user': user, 'weeks': data.weeks, 'series': data.series, 'target': data.target, 'ratio': data.ratio, 'id': chart_id}) }}
    {% endblock %}
{% endembed %}

{% if not kimai_context.javascriptRequest %}
<script type="text/javascript">
    document.addEventListener('kimai.initialized', function() {
        KimaiPaginatedBoxWidget.create('#LastWeeksBillableChartBox');
    });
</script>
{% endif %}
