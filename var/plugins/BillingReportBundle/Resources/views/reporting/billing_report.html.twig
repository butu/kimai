{% extends 'reporting/layout.html.twig' %}

{% block report %}
    {% embed '@theme/embeds/card.html.twig' %}
        {% block box_title %}{{ 'report_billing'|trans({}, 'reporting') }}{% endblock %}
        {% block box_body %}
            {% if entries is empty %}
                <div class="alert alert-info" role="alert">
                    {{ 'error.no_entries_found'|trans }}
                </div>
            {% else %}
                {% set totalFlat = 0 %}
                {% set totalAtCost = 0 %}
                {% set totalOverall = 0 %}
                {% set redmineBase = 'https://kunden.webprofil.at/time_entries?set_filter=1&sort=spent_on%3Adesc&f%5B%5D=spent_on&op%5Bspent_on%5D=%3E%3C&f%5B%5D=user_id&op%5Buser_id%5D=%3D&f%5B%5D=&c%5B%5D=project&c%5B%5D=spent_on&c%5B%5D=hours&c%5B%5D=comments&c%5B%5D=user&c%5B%5D=activity&c%5B%5D=issue&c%5B%5D=cf_13&c%5B%5D=cf_12&group_by=project&t%5B%5D=hours&t%5B%5D=' %}

                <div class="table-responsive">
                    <table class="table table-striped table-bordered dataTable">
                        <thead>
                            <tr>
                                <th>{{ 'username'|trans }}</th>
                                <th class="text-end">{{ 'billingClassification_atcost'|trans({}, 'reporting') }}</th>
                                <th class="text-end">{{ 'billingClassification_flat'|trans({}, 'reporting') }}</th>
                                <th class="text-end">{{ 'total'|trans }}</th>
                                <th class="text-center">{{ 'redmine'|trans({}, 'reporting') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for entry in entries %}
                            {% set totalFlat = totalFlat + entry.flatHours %}
                            {% set totalAtCost = totalAtCost + entry.atCostHours %}
                            {% set totalOverall = totalOverall + entry.flatHours + entry.atCostHours %}
                            <tr>
                                <td>{{ entry.userDisplayName }}</td>
                                <td class="text-end">
                                    {%- if entry.atCostHours > 0 and entry.atCostProjectIds is not empty and entry.user is not null and begin is not null and end is not null -%}
                                        {% set url = path('admin_timesheet', {'billable': 1, 'state': 3, 'users': [entry.user.id], 'daterange': begin|date('Y-m-d') ~ ' - ' ~ end|date('Y-m-d'), 'performSearch': 1}) %}
                                        {% for pid in entry.atCostProjectIds %}
                                            {% set url = url ~ '&projects%5B%5D=' ~ pid %}
                                        {% endfor %}
                                        <a href="{{ url }}">{{ entry.atCostHours|number_format(2, ',', '.') }} h</a>
                                    {%- else -%}
                                        {{ entry.atCostHours|number_format(2, ',', '.') }} h
                                    {%- endif -%}
                                </td>
                                <td class="text-end">
                                    {%- if entry.flatHours > 0 and entry.flatProjectIds is not empty and entry.user is not null and begin is not null and end is not null -%}
                                        {% set url = path('admin_timesheet', {'billable': 1, 'state': 3, 'users': [entry.user.id], 'daterange': begin|date('Y-m-d') ~ ' - ' ~ end|date('Y-m-d'), 'performSearch': 1}) %}
                                        {% for pid in entry.flatProjectIds %}
                                            {% set url = url ~ '&projects%5B%5D=' ~ pid %}
                                        {% endfor %}
                                        <a href="{{ url }}">{{ entry.flatHours|number_format(2, ',', '.') }} h</a>
                                    {%- else -%}
                                        {{ entry.flatHours|number_format(2, ',', '.') }} h
                                    {%- endif -%}
                                </td>
                                <td class="text-end">{{ (entry.flatHours + entry.atCostHours)|number_format(2, ',', '.') }} h</td>
                                <td class="text-center">
                                    {%- if entry.redmineUserId is not null and begin is not null and end is not null -%}
                                        {% set rmUrl = redmineBase ~ '&v%5Bspent_on%5D%5B%5D=' ~ begin|date('Y-m-d') ~ '&v%5Bspent_on%5D%5B%5D=' ~ end|date('Y-m-d') ~ '&v%5Buser_id%5D%5B%5D=' ~ entry.redmineUserId %}
                                        <a href="{{ rmUrl }}" target="_blank" title="Redmine">{{ 'redmine_link'|trans({}, 'reporting') }}</a>
                                    {%- endif -%}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr class="summary">
                                <th>{{ 'summary'|trans }}</th>
                                <th class="text-end">{{ totalAtCost|number_format(2, ',', '.') }} h</th>
                                <th class="text-end">{{ totalFlat|number_format(2, ',', '.') }} h</th>
                                <th class="text-end">{{ totalOverall|number_format(2, ',', '.') }} h</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
{% endblock %}
