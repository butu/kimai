{% extends 'reporting/layout.html.twig' %}
{% import _self as helper %}

{% macro hours_link(hours, projectIds, userId, begin, end) %}
    {%- if hours > 0 and projectIds is not empty and userId is not null and begin is not null and end is not null -%}
        {% set params = {
            'billable': 1,
            'state': 3,
            'users[]': [userId],
            'projects[]': projectIds,
            'daterange': begin|date('Y-m-d') ~ ' - ' ~ end|date('Y-m-d'),
            'performSearch': 1
        } %}
        <a href="{{ path('admin_timesheet', params) }}">{{ hours|number_format(2, ',', '.') }} h</a>
    {%- else -%}
        {{ hours|number_format(2, ',', '.') }} h
    {%- endif -%}
{% endmacro %}

{% block report %}
    {% embed '@theme/embeds/card.html.twig' %}
        {% block box_title %}{{ 'report_billing'|trans({}, 'reporting') }}{% endblock %}
        {% block box_body %}
            {% if entries is empty %}
                <div class="alert alert-info" role="alert">
                    {{ 'error.no_entries_found'|trans }}
                </div>
            {% else %}
                {% set totalFlat = 0 %}
                {% set totalAtCost = 0 %}
                {% set totalUnknown = 0 %}
                {% set totalOverall = 0 %}

                <div class="table-responsive">
                    <table class="table table-striped table-bordered dataTable">
                        <thead>
                            <tr>
                                <th>{{ 'username'|trans }}</th>
                                <th class="text-end">{{ 'billingClassification_atcost'|trans({}, 'reporting') }}</th>
                                <th class="text-end">{{ 'billingClassification_flat'|trans({}, 'reporting') }}</th>
                                <th class="text-end">{{ 'billingClassification_unknown'|trans({}, 'reporting') }}</th>
                                <th class="text-end">{{ 'total'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for entry in entries %}
                            {% set totalFlat = totalFlat + entry.flatHours %}
                            {% set totalAtCost = totalAtCost + entry.atCostHours %}
                            {% set totalUnknown = totalUnknown + entry.unknownHours %}
                            {% set totalOverall = totalOverall + entry.totalHours %}
                            <tr>
                                <td>{{ entry.userDisplayName }}</td>
                                <td class="text-end">{{ helper.hours_link(entry.atCostHours, entry.atCostProjectIds, entry.user.id, begin, end) }}</td>
                                <td class="text-end">{{ helper.hours_link(entry.flatHours, entry.flatProjectIds, entry.user.id, begin, end) }}</td>
                                <td class="text-end">{{ helper.hours_link(entry.unknownHours, entry.unknownProjectIds, entry.user.id, begin, end) }}</td>
                                <td class="text-end">{{ entry.totalHours|number_format(2, ',', '.') }} h</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr class="summary">
                                <th>{{ 'summary'|trans }}</th>
                                <th class="text-end">{{ totalAtCost|number_format(2, ',', '.') }} h</th>
                                <th class="text-end">{{ totalFlat|number_format(2, ',', '.') }} h</th>
                                <th class="text-end">{{ totalUnknown|number_format(2, ',', '.') }} h</th>
                                <th class="text-end">{{ totalOverall|number_format(2, ',', '.') }} h</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
{% endblock %}
